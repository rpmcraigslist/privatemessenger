{
  "name": "private-messenger",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Real-time, mobile-first messenger PWA on AWS (Cognito + AppSync + DynamoDB + S3) using Amplify Gen 2.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "sandbox": "ampx sandbox",
    "sandbox:once": "ampx sandbox --once",
    "deploy": "ampx pipeline-deploy --branch main",
    "generate-outputs": "ampx generate outputs",
    "docker:dev": "docker compose up web",
    "docker:local": "docker compose -f docker-compose.local.yml up",
    "docker:aws": "docker compose --profile aws up",
    "docker:prod": "docker compose --profile prod up web-prod"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^6.15.4",
    "@aws-sdk/client-cognito-identity-provider": "^3.1071.0",
    "@aws-sdk/client-s3": "^3.1069.0",
    "@aws-sdk/client-sns": "^3.1071.0",
    "@aws-sdk/s3-request-presigner": "^3.1069.0",
    "aws-amplify": "^6.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.23.0",
    "@aws-amplify/backend-cli": "^1.8.3",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "aws-cdk-lib": "^2.259.0",
    "constructs": "^10.6.0",
    "esbuild": "^0.25.12",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^1.3.0"
  },
  "overrides": {
    "esbuild": "^0.25.12",
    "uuid": "^11.1.0",
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@smithy/config-resolver": "^4.4.0",
    "@smithy/middleware-retry": "^4.2.5",
    "fast-xml-parser": "^5.9.0",
    "fast-xml-builder": "^1.2.0",
    "handlebars": "^4.7.9",
    "@aws-amplify/data-construct": {
      "fast-xml-parser": "^5.9.0",
      "fast-xml-builder": "^1.2.0",
      "@opentelemetry/core": "^2.8.0"
    },
    "@aws-amplify/graphql-api-construct": {
      "fast-xml-parser": "^5.9.0",
      "fast-xml-builder": "^1.2.0",
      "@opentelemetry/core": "^2.8.0"
    }
  }
}

{
  "name": "private-messenger",
  "private": true,
  "version": "1.5.0",
  "type": "module",
  "description": "Real-time, mobile-first messenger PWA on AWS (Cognito + AppSync + DynamoDB + S3) using Amplify Gen 2.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "typecheck:backend": "tsc -p amplify/tsconfig.json --noEmit",
    "verify": "npm run typecheck && npm run typecheck:backend && npm run test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "sandbox": "ampx sandbox",
    "sandbox:once": "ampx sandbox --once",
    "deploy": "ampx pipeline-deploy --branch main",
    "migrate:export": "tsx scripts/region-migration/export.ts",
    "migrate:import": "tsx scripts/region-migration/import.ts",
    "migrate:teardown": "tsx scripts/region-migration/teardown.ts",
    "cleanup:list-s3": "tsx scripts/cleanup-orphan-s3.ts",
    "docker:dev": "docker compose up web",
    "docker:local": "docker compose -f docker-compose.local.yml up",
    "docker:aws": "docker compose --profile aws up",
    "docker:prod": "docker compose --profile prod up web-prod"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^6.15.4",
    "@aws-sdk/client-cognito-identity-provider": "^3.1071.0",
    "@aws-sdk/client-s3": "^3.1069.0",
    "@aws-sdk/client-ses": "^3.1071.0",
    "@aws-sdk/client-sns": "^3.1071.0",
    "@aws-sdk/s3-request-presigner": "^3.1069.0",
    "aws-amplify": "^6.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.23.0",
    "@aws-amplify/backend-cli": "^1.8.3",
    "@aws-sdk/client-cloudformation": "^3.1071.0",
    "@aws-sdk/client-dynamodb": "^3.1071.0",
    "@aws-sdk/lib-dynamodb": "^3.1071.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "aws-cdk-lib": "^2.259.0",
    "constructs": "^10.6.0",
    "esbuild": "^0.25.12",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.4",
    "jsdom": "^26.1.0"
  }
}
